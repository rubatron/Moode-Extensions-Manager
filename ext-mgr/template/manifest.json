{
  "id": "auto-generate",
  "name": "Template Extension",
  "version": "0.1.0",
  "template_kit_version": "1.0.0",
  "author": "Your Name",
  "license": "GPL-3.0-or-later",
  "description": "Starter template generated by ext-mgr import wizard.",
  "repository": "",
  "main": "template.php",
  "ext_mgr": {
    "enabled": true,
    "state": "active",
    "stageProfile": "visible-by-default",
    "menuVisibility": {
      "m": true,
      "library": true,
      "system": false
    },
    "settingsCardOnly": true,
    "settingsPage": "/auto-generate.php",
    "iconClass": "fa-solid fa-sharp fa-puzzle-piece",
    "service": {
      "name": "auto-generate.service",
      "requiresExtMgr": true,
      "parentService": "moode-extmgr.service",
      "dependencies": []
    },
    "logging": {
      "localDir": "logs",
      "globalDir": "/var/www/extensions/sys/logs/extensionslogs/auto-generate",
      "files": [
        "install.log",
        "system.log",
        "error.log"
      ]
    },
    "install": {
      "packages": [],
      "script": "scripts/install.sh"
    },
    "boot_config": []
  }
}
