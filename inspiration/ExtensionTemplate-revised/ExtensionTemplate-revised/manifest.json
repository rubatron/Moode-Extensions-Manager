{
    "id": "template-extension",
    "name": "Template Extension",
    "version": "0.1.0",
    "main": "template.php",
    "ext_mgr": {
        "enabled": true,
        "state": "active",
        "stageProfile": "visible-by-default",
        "menuVisibility": {
            "m": true,
            "library": true,
            "system": false
        },
        "settingsCardOnly": true,
        "iconClass": "fa-solid fa-sharp fa-puzzle-piece",
        "service": {
            "name": "template-extension.service",
            "requiresExtMgr": true,
            "parentService": "moode-extmgr.service",
            "dependencies": [
                "moode-extmgr.service"
            ]
        },
        "logging": {
            "localDir": "logs",
            "globalDir": "/var/www/extensions/sys/logs/extensionslogs/template-extension",
            "files": [
                "install.log",
                "system.log",
                "error.log"
            ]
        },
        "install": {
            "packages": [],
            "script": "scripts/install.sh"
        },
        "type": "functionality"
    }
}